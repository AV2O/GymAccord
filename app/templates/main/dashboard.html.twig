{% extends 'layout.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	{# Garde le CSS global (app.css) #}
	<link rel="stylesheet" href="{{ asset('styles/style.css') }}">
{% endblock %}

{# 3. On met le contenu spécifique de la page #}
{% block content %}
	<main class="dashboard">
		<section class="portrait-container">
			<div class="portrait">
				<div>
					<h1>Bonjour
						{{ app.user.firstName }}
						!</h1>
					<p>Prêt pour l'impact ?</p>
				</div>

				{% if app.user.profilePicture %}
					<img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" class="profile-img-main"/>
				{% else %}
					<img src="{{ asset('images/avatar-default-green.svg') }}" class="profile-img-main default-avatar"/>
				{% endif %}

				{# Garde UNIQUEMENT celui-ci #}
				<a href="#" class="edit-profile-btn">
					<img src="{{ asset('images/pen-svgrepo-com.svg') }}" alt="Modifier la photo">
				</a>
			</div>

			{# SUPPRIME TOUT CE QUI ÉTAIT ICI (le portrait-wrapper) #}
		</section>

		<article>
			<div class="container-status">
				<section class="status-day">
					<img src="{{ asset('images/calendar-alt-svgrepo-com.svg') }}" alt=""/>
					<div>
						<h2>{{ date().diff(app.user.createdAt).days }}</h2>
						<p>jours</p>
						<p>membre deupis</p>
					</div>
				</section>

				<section class="status-forfait">
					<div class="actif">
						<h2>forfait premium</h2>
						<p>actif</p>
					</div>

					<div class="modif">
						<a href="#"><img src="{{ asset('images/pen-svgrepo-com.svg') }}" alt="modifier"/></a>
						<a href="#"><img src="{{ asset('images/delete-2-svgrepo-com.svg') }}" alt="supprimer"/></a>
					</div>
				</section>
			</div>
		</article>

		<section class="next-sessions">

			<div class="session-header">
				<h2>Mes prochaines séances</h2>
				<a href="#" class="view-all">Voir tout</a>
			</div>

			<div class="session-list">
				<article class="session-card">
					<div class="session-img">
						<img src="{{ asset('images/photo/banc-muscu.jpg') }}" alt="Crossfit">
					</div>
					<div class="session-info">
						<p class="session-date">Demain • 18:30</p>
						<h3>Power Crossfit</h3>
					</div>
				</article>

				<article class="session-card">
					<div class="session-img">
						<img src="{{ asset('images/photo/tapis-course.jpg') }}" alt="Yoga">
					</div>
					<div class="session-info">
						<p class="session-date">Mercredi • 07:00</p>
						<h3>Vinyasa Flow</h3>
					</div>
				</article>
			</div>
		</section>

		<section class="promo-banner">
			<h2 class="promo-title">Vibrance & Puissance</h2>

			<div class="hero-card">
				<div class="hero-content">
					<h2>Dépasse tes
						<span>limites</span>.</h2>
					<p>Le succès n'est pas une destination, c'est une discipline. Rejoins la meute.</p>
				</div>
			</div>

			<a href="{{ path('app_reservation') }}" class="btn-primary-large">Réserver une séance</a>
		</section>
	</main>


	<div id="photoModal" class="modal">
		<div class="modal-content">
			<span class="close-modal">&times;</span>
			<h2>Modifier ma photo</h2>

			{{ form_start(form, {'action': path('app_profile_update_photo'), 'method': 'POST'}) }}
			{{ form_widget(form.profilePicture) }}

			<div class="modal-actions">
				<button type="submit" class="btn-gym">ENREGISTRER</button>
				<button type="button" class="btn-gym btn-gym-outline btn-cancel">ANNULER</button>

				{% if app.user.profilePicture %}
					<a href="{{ path('app_profile_delete_photo') }}" class="btn-delete" onclick="return confirm('Supprimer ta photo de profil ?')">
						Supprimer la photo actuelle
					</a>
				{% endif %}
			</div>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
