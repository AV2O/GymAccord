{% extends 'layout.html.twig' %}

{% block content %}

	<main class="app">
		<section class="hero-banner">
			<div class="hero-text">
				<h1>La force dans l'accord</h1>
				<p>L'excellence physique rencontre la précision technique.</p>
			</div>
		</section>

		<!-- BIO -->
		<section class="bio">
			<div class="hero-bio">
				<h2>Gym Accord</h2>
				<div class="bio-text">
					<p>Notre philosophie repose sur l'harmonie entre le corps et l'esprit.</p>
					<p>Dans notre espace de 500m², nous combinons les techniques de musculation traditionnelles avec les dernières innovations en matière de biomécanique.</p>
					<p>Chaque athlète bénéficie d'un accompagnement sur mesure pour atteindre des objectifs de haut niveau.</p>
				</div>
				<a class="btn-green" href="{{ path('app_a-propos') }}">voir plus ...</a>
			</div>

			<!-- GALERIE -->
			<article class="galery-img">
				<div class="galery">
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/abdosFlash.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/abdosFlash.jpg') }}" alt="Séances de abdos flash" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Abdos</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/BBE.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/BBE.jpg') }}" alt="Séance BBE - renforcement musculaire en groupe" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances BBE</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/bodyPump.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/bodyPump.jpg') }}" alt="Séance de body pump" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Body Pump</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/boxing.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/boxing.jpg') }}" alt="Séance de boxing" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Boxing</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/CAF.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/CAF.jpg') }}" alt="Séance CAF - cours collectif cardio abdos fessiers" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances CAF</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/cardioFlash.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/cardioFlash.jpg') }}" alt="Séance de cardio flash" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Cardio Flash</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/crossTraining.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/crossTraining.jpg') }}" alt="Séance de cross-training" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Cross - Training</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/pilates.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/pilates.jpg') }}" alt="Séance de pilâtes" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances abdos de Pilâtes</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/sportSante.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/sportSante.jpg') }}" alt="Séance de sport santé" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Sport Santé</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/step.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/step.jpg') }}" alt="Séance de step" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances de Step</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/stretching.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/stretching.jpg') }}" alt="Séance de stretching" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Stretching</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/training.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/training.png') }}" alt="Séance de training" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Training</figcaption>
					</figure>
					<figure class="photo-cv">
						<picture>
							<source srcset="{{ asset('images/photo/yoga.webp') }}" type="image/webp">
							<img src="{{ asset('images/photo/yoga.jpg') }}" alt="Séance de yoga" loading="lazy" width="400" height="300">
						</picture>
						<figcaption>Nos séances Yoga</figcaption>
					</figure>
				</div>
			</article>
		</section>

		<!-- HORAIRES -->
		<section class="time">
			<h2 class="studio-title">
				<div class="text-group">Horaire du
					<span>studio Gym</span>
				</div>
			</h2>
			<p>Notre studio s'adapte à votre rythme. Des sessions matinales explosives aux entraînements nocturnes, la discipline n'a pas d'heure.</p>
			<div class="card">
				<p>Ouverture 7/7J</p>
				<p>Accès à la salle 24/24h</p>
				<p>Cours de 6h30 / 22h30</p>
			</div>
			<a class="btn-green" href="{{ path('app_coursCo') }}">PROGRAMME</a>
		</section>

		<!-- COMMENTAIRE -->
		<section class="commentary" id="commentaires">
			<div>
				<h2 class="commentary-title">C'EST VOUS QUI EN PARLEZ LE MIEUX...</h2>
			</div>

			<div class="commentary-list">
				{% for comment in comments %}
					<div class="commentary-item">
						<p class="commentary-text">{{ comment.contenu }}</p>
						<div class="commentary-info">
							<p class="commentary-author">{{ comment.authorName }}</p>
							<p class="commentary-date">{{ comment.createdAt|date('d/m/Y') }}</p>
						</div>
					</div>
				{% else %}
					<p class="no-comment">Soyez le premier à donner votre avis !</p>
				{% endfor %}
			</div>

			<article class="commentary-form-container">
				<h2>Laissez votre commentaire ...</h2>
				{% if app.user %}
					<form action="{{ path('app_comment_add') }}" method="POST" class="form-group">
						<textarea name="contenu" id="contenu" placeholder="Votre message ... (max 150 caractères)" maxlength="150" required></textarea>
						<button type="submit" class="btn-primary">Publier mon avis</button>
					</form>
				{% else %}
					<p class="login-msg">
						<a class="btn-green" href="{{ path('app_login') }}">Connectez-vous</a>
					</p>
				{% endif %}
			</article>
		</section>

		<!-- FORMULAIRE CONTACT -->
		<section id="contact" class="form-contact">
			<div class="container-form">
				<div class="hero-form-contact">
					<h2>N'hésitez pas à nous contacter</h2>
					<p>Des questions sur nos programmes ? Ecrivez-nous directement.</p>
					<div class="hero-contact">
						<div>
							<p>Téléphone :</p>
							<a href="tel:+330123456789" aria-label="Appeler le 01 23 45 67 89">0123456789</a>
						</div>
						<div>
							<p>Adresse :</p>
							<a href="https://maps.google.com/?q=1+rue+du+capitole+14790+Verson" target="_blank" rel="noopener noreferrer" aria-label="Voir l'adresse sur Google Maps">1 rue du capitole, 14790 Verson</a>
						</div>
					</div>
				</div>
				<form id="contact-form" action="{{ path('app_contact_send') }}" method="POST" novalidate>
					<div class="form-group">
						<label for="prenom">Prénom</label>
						<input type="text" id="prenom" name="prenom" placeholder="Votre prénom">
						<span class="error-message" id="error-prenom"></span>
					</div>
					<div class="form-group">
						<label for="email">Email *</label>
						<input type="email" id="email" name="email" placeholder="Email">
						<span class="error-message" id="error-email"></span>
					</div>
					<div class="form-group">
						<label for="message">Message *</label>
						<textarea id="message" name="message" placeholder="Message"></textarea>
						<span class="error-message" id="error-message"></span>
					</div>
					<p class="obligatoire-txt">Tous les champs suivis d'une * sont obligatoires</p>
					<div class="checkbox-container">
						<div class="form-checkbox-group">
							<input type="checkbox" id="consentement" name="consentement">
							<label for="consentement">J'accepte que mes données soient collectées pour le traitement de mon inscription et la gestion de mon abonnement conformément à la politique de confidentialité. *</label>
						</div>
						<span class="error-message" id="error-consentement"></span>
					</div>
					<button type="submit" class="btn-primary">Envoyer</button>
				</form>
			</div>
		</section>
	</main>
{% endblock %}
