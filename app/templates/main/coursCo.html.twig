{% extends 'layout.html.twig' %}

{% block content %}

	<main class="coursCo">
		<h1>Cours Collectifs</h1>

		{% for cat, workshops in groupedWorkshops %}
			<section class="workshop">
				<h2 class="workshop-title">{{ cat|upper }}</h2>

				<article class="card-workshop">
					{% for workshop in workshops %}

						{% set style = "" %}
						{% set infoBarStyle = "" %}

						{% if cat|lower == 'renforcement musculaire' %}
							{% set style = "black" %}
							{% set infoBarStyle = "black" %}
						{% elseif cat|lower == 'cross - training' %}
							{% set style = "white" %}
							{% set infoBarStyle = "" %}
						{% endif %}

						<details class="workshop-item {{ style }}"
						         name="{{ cat|lower|replace({' ': '-', '/': '', '.': '', '(': '', ')': ''}) }}">

							<summary>{{ workshop.nameClass|lower }}</summary>

							<div class="content-card">
								<img class="workshop-img"
								     src="{{ asset('images/photo/' ~ workshop.image) }}"
								     alt="{{ workshop.nameClass }}"/>
								<p>{{ workshop.descriptionClass }}</p>

								<p class="info-bar {{ infoBarStyle }}">
									<img src="{{ asset('images/chronometer-svgrepo-com.svg') }}" alt="chronomètre"/>
									60 min
									&bull;
									{% set places = workshop.maxCapacity - workshop.reservations|length %}
									{% if places > 0 %}
										<span class="places-dispo">{{ places }} place{{ places > 1 ? 's' : '' }}</span>
									{% else %}
										<span class="places-complet">Complet</span>
									{% endif %}
								</p>

								{% if app.user %}
									<a href="{{ path('app_reservation_with_id', {'id': workshop.id}) }}"
									   class="btn-primary{% if places <= 0 %} btn-disabled{% endif %}"
									   {% if places <= 0 %}aria-disabled="true" onclick="return false;"{% endif %}>
										{% if places > 0 %}Réserver ce cours{% else %}Complet{% endif %}
									</a>
								{% else %}
									<a href="#" class="btn-primary btn-trigger-login">
										Réserver ce cours
									</a>
								{% endif %}
							</div>

						</details>

					{% endfor %}
				</article>
			</section>
		{% endfor %}

	</main>

	{# MODALE CONNEXION REQUISE #}
	<div id="loginRequiredModal" class="modal">
		<div class="modal-content">
			<span class="close-modal">&times;</span>
			<h2>Action requise</h2>
			<p>Vous devez être connecté pour réserver une séance.</p>
			<div class="modal-actions">
				<a href="{{ path('app_login') }}" class="btn-gym">SE CONNECTER</a>
				<button type="button" class="btn-gym btn-gym-outline btn-cancel">ANNULER</button>
			</div>
		</div>
	</div>

{% endblock %}
